<section class="block contact" id="contact">
  <div class="wrap contact-grid">
    <div class="reveal">
      <span class="eyebrow">Get In Touch</span>
      <h2 class="display">Drop by the chair.</h2>
      <p class="lead">Right in the neighbourhood on Bathurst St, Eli's is ready for whatever you need — a cut, a trim, or a quick question about booking. Reach out any time.</p>
      <div class="call">Call us <a href="tel:+14162242877">(416)&nbsp;224-2877</a></div>
      <div class="meta">
        <div><div class="lbl">Find us</div><div class="val">4128 Bathurst St, Toronto, ON M3H 3P4</div></div>
        <div><div class="lbl">Hours</div><div class="val">
          <span>Sun · 8 AM – 5 PM</span>
          <span>Mon – Thu · 8 AM – 7 PM</span>
          <span>Fri · 8 AM – 5 PM</span>
          <span>Sat · Closed (Shomer Shabbat)</span>
        </div></div>
      </div>
    </div>
    <div class="reveal d1">
      <div class="map">
        <iframe title="Map to Eli's Barbershop" loading="lazy"
          src="https://maps.google.com/maps?q=4128+Bathurst+St+Toronto+ON+M3H+3P4&t=m&z=15&output=embed&iwloc=near"></iframe>
      </div>
    </div>
  </div>
</section>

<section class="block" id="pricing">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">Our Pricing</span>
      <h2 class="display">Simple, honest pricing.</h2>
      <p>Quality work at a fair, flat rate. Walk in or call ahead — same great cut either way.</p>
    </div>
    <div class="prices">
      <article class="price reveal">
        <span class="tier">Men's Haircut</span>
        <div class="amt"><span class="cur">$</span>25</div>
        <p class="desc">Standard price for a gents haircut.</p>
        <a class="btn btn--amber btn--block" href="tel:+14162242877">Call to book <span class="arw">→</span></a>
      </article>
      <article class="price reveal d1">
        <span class="tier">Beard Trim</span>
        <div class="amt"><span class="cur">$</span>10</div>
        <p class="desc">Standard price for a beard trim or shave.</p>
        <a class="btn btn--block" href="tel:+14162242877">Call to book <span class="arw">→</span></a>
      </article>
    </div>
    <p class="price-note reveal">Prices are inclusive of taxes.</p>
  </div>
</section>

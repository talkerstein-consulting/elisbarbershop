---
---
<section class="hero" id="top">
  <div class="hero-sticky">
    <img class="hero-poster" id="heroPoster" src="/media/hero-poster.webp" alt="" aria-hidden="true" />
    <canvas class="hero-canvas" id="heroCanvas"></canvas>
    <video class="hero-fallback" id="heroVideo" muted playsinline preload="none" aria-hidden="true"
           src="/banner.mp4"></video>
    <div class="hero-scrim"></div>
    <div class="hero-content" id="heroContent">
      <h1 class="display">Welcome to Eli&rsquo;s Barbershop<br><span class="amber">Gents Salon in Toronto</span></h1>
    </div>

    <!-- reveal phase 1: heritage statement over the video -->
    <div class="hero-layer hero-statement" id="heroStatement" aria-hidden="true">
      <span class="eyebrow">Since 2017</span>
      <h2>The timeless craft of a proper barbershop.</h2>
      <p>On Bathurst St in Toronto &mdash; old-school heritage, today&rsquo;s sharpest work, and a chair that&rsquo;s served the neighbourhood for years.</p>
    </div>

    <!-- reveal phase 2: service cards wipe in over the video -->
    <div class="hero-layer hero-cards" id="heroCards" aria-hidden="true">
      <div class="hero-cards-grid" id="heroCardsGrid">
        <div class="glass-card">
          <div>
            <div class="chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M20 4L8.12 15.88M14.47 14.48L20 20M8.12 8.12L12 12"/></svg></div>
            <h3>Men&rsquo;s Haircut</h3>
            <p>Skin fades, clean tapers and classic scissor work &mdash; shaped to you and finished sharp.</p>
          </div>
          <span class="tag">Gents Cut</span>
        </div>
        <div class="glass-card">
          <div>
            <div class="chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 3v18M8 7l-4 4 4 4M16 7l4 4-4 4"/></svg></div>
            <h3>Beard Trim</h3>
            <p>Sharp line-ups and shape-ups, a tidy trim, or a smooth straight-razor finish.</p>
          </div>
          <span class="tag">Beard Trim</span>
        </div>
        <div class="glass-card">
          <div>
            <div class="chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/></svg></div>
            <h3>Salon Services</h3>
            <p>Full-service grooming and styling for every look &mdash; ask the chair for the full menu.</p>
          </div>
          <span class="tag">Walk-ins Welcome</span>
        </div>
      </div>
    </div>
    <div class="scroll-ind" id="scrollHint" role="button" tabindex="0" aria-label="Scroll to explore">
      <span>Scroll to explore</span>
      <span class="chev" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></span>
    </div>
  </div>
</section>

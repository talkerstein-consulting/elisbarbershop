---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About Us - Eli's Barbershop Toronto" description="Learn about Eli Chanimov and Eli's Barbershop - Toronto's premier gents barbershop." active="about">
  <section class="page-hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>About Us</h1>
      <div class="hero-divider"><span></span><span class="scissors">✂</span><span></span></div>
    </div>
  </section>
  <section class="about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2 class="section-title">Meet Eli Chanimov</h2>
          <p>Welcome to Eli's Barbershop - Toronto's trusted gents salon. Owner and head barber Eli Chanimov brings years of experience and a genuine passion for the craft to every cut.</p>
          <p>Located at 4128 Bathurst St in the heart of Toronto, we've built a reputation for exceptional service, fair pricing, and a relaxed atmosphere where every client feels at home.</p>
          <p>Whether you're coming in for a fresh fade, a classic cut, or a beard trim, we take the time to understand what you want and deliver results you'll love.</p>
          <p>We are a Shomer Shabbat establishment - closed on Saturdays and Jewish holidays.</p>
          <div class="about-cta">
            <a href="tel:+14162242877" class="btn btn-primary">Call Us: (+1) 416 224 2877</a>
            <a href="/contact" class="btn btn-outline">Contact Us</a>
          </div>
        </div>
        <div class="about-img">
          <img src="https://elisbarbershop.com/wp-content/uploads/elementor/thumbs/elisbarbershop-4-qwqqakyrn6xux071eqdmnjrv5jlfecld9vfmdwnmf4.jpg" alt="Eli at work">
        </div>
      </div>
    </div>
  </section>
  <section class="values-section">
    <div class="container">
      <h2 class="section-title light">Our Values</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon"><img src="https://elisbarbershop.com/wp-content/uploads/2024/11/Icon-3.png.webp" alt="Expertise"></div>
          <h3>Expertise</h3>
          <p>Years of professional barbering experience, keeping up with trends while mastering the classics.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><img src="https://elisbarbershop.com/wp-content/uploads/2024/11/Icon-2.png.webp" alt="Value"></div>
          <h3>Fair Pricing</h3>
          <p>Premium quality at honest prices. No hidden fees, no surprises - just great cuts at $25.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><img src="https://elisbarbershop.com/wp-content/uploads/2024/11/Icon-4.png.webp" alt="Community"></div>
          <h3>Community</h3>
          <p>A welcoming space for everyone. We take pride in being part of the Toronto community.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

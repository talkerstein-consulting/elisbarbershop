---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact Us - Eli's Barbershop Toronto" description="Contact Eli's Barbershop in Toronto. Call us or visit us at 4128 Bathurst St." active="contact">
  <section class="page-hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Contact Us</h1>
      <div class="hero-divider"><span></span><span class="scissors">✂</span><span></span></div>
    </div>
  </section>
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2 class="section-title">Get In Touch</h2>
          <p>Have questions about our services or want to book an appointment? Reach out to us by phone or visit us in person. We'd love to help you find the perfect look.</p>
          <div class="contact-details">
            <div class="contact-detail-item">
              <div class="contact-detail-icon">📞</div>
              <div>
                <h3>Phone</h3>
                <a href="tel:+14162242877">(+1) 416 224 2877</a>
              </div>
            </div>
            <div class="contact-detail-item">
              <div class="contact-detail-icon">📍</div>
              <div>
                <h3>Address</h3>
                <p>4128 Bathurst St, Toronto, ON M3H 3P4</p>
              </div>
            </div>
            <div class="contact-detail-item">
              <div class="contact-detail-icon">🕐</div>
              <div>
                <h3>Hours of Operation</h3>
                <ul class="hours-list">
                  <li>Sun: 8 AM - 5 PM</li>
                  <li>Mon - Thu: 8 AM - 7 PM</li>
                  <li>Fri: 8 AM - 5 PM</li>
                  <li>Sat: Closed (Shomer Shabbat)</li>
                </ul>
              </div>
            </div>
          </div>
          <div class="contact-social">
            <h3>Follow Us</h3>
            <div class="footer-social">
              <a href="https://www.facebook.com/elisalonyorkdowns/" class="social-btn" target="_blank" rel="noopener">f</a>
              <a href="https://www.instagram.com/explore/locations/707157206157190/elis-salon-barber-shop/" class="social-btn" target="_blank" rel="noopener">in</a>
            </div>
          </div>
        </div>
        <div class="contact-map">
          <h2 class="section-title">Find Us</h2>
          <div class="map-placeholder">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2882.1!2d-79.4368!3d43.7587!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s4128+Bathurst+St%2C+Toronto%2C+ON+M3H+3P4!5e0!3m2!1sen!2sca!4v1"
              width="100%"
              height="400"
              style="border:0; border-radius: 8px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
          <div class="call-cta">
            <a href="tel:+14162242877" class="btn btn-primary" style="width:100%;text-align:center;margin-top:1.5rem;">Call Now: (+1) 416 224 2877</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

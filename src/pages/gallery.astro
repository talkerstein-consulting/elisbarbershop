---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Gallery - Eli's Barbershop Toronto" description="Browse our gallery of haircuts and styles at Eli's Barbershop Toronto." active="gallery">
  <section class="page-hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Our Gallery</h1>
      <div class="hero-divider"><span></span><span class="scissors">✂</span><span></span></div>
    </div>
  </section>
  <section class="gallery-page-section">
    <div class="container">
      <h2 class="section-title">Our Work</h2>
      <p class="section-intro">Browse a selection of cuts from Eli's Barbershop. Every client gets a personalized cut tailored to their style.</p>
      <div class="gallery-grid">
        <div class="gallery-item"><img src="https://elisbarbershop.com/wp-content/uploads/elementor/thumbs/elisbarbershop-1-qwqqah7evuspmkci0or4dkq0s03yjk6fxctogst740.jpg" alt="Eli Barbershop Cut 1"></div>
        <div class="gallery-item"><img src="https://elisbarbershop.com/wp-content/uploads/elementor/thumbs/elisbarbershop-2-qwqqai592otzy6b4v75qy2hhddzbr9a69hh5y2rsxs.jpg" alt="Eli Barbershop Cut 2"></div>
        <div class="gallery-item"><img src="https://elisbarbershop.com/wp-content/uploads/elementor/thumbs/elisbarbershop-3-qwqqak0xgcwkle8ek7z0320ek5q26nhmxqs4wmp0lc.jpg" alt="Eli Barbershop Cut 3"></div>
        <div class="gallery-item"><img src="https://elisbarbershop.com/wp-content/uploads/elementor/thumbs/elisbarbershop-4-qwqqakyrn6xux071eqdmnjrv5jlfecld9vfmdwnmf4.jpg" alt="Eli Barbershop Cut 4"></div>
        <div class="gallery-item"><img src="https://elisbarbershop.com/wp-content/uploads/elementor/thumbs/elisbarbershop-5-qwqqamug0v0fk84b3r6vsjascbc5tqsty4qlcgku2o.jpg" alt="Eli Barbershop Cut 5"></div>
        <div class="gallery-item"><img src="https://elisbarbershop.com/wp-content/uploads/elementor/thumbs/elisbarbershop-6-qwqqaoq4ej307g1kss04xitpj32w950ame1kb0i1q8.jpg" alt="Eli Barbershop Cut 6"></div>
      </div>
      <div class="gallery-cta">
        <p>Ready for your next look? Book your appointment today.</p>
        <a href="tel:+14162242877" class="btn btn-primary">Call Us: (+1) 416 224 2877</a>
      </div>
    </div>
  </section>
</Layout>

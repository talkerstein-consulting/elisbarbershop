---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Gallery - Eli's Barbershop Toronto" description="Browse our gallery of haircuts and styles at Eli's Barbershop Toronto." active="gallery">
  <section class="page-hero">
    <div class="hero-slideshow" aria-hidden="true">
      <div class="hero-slide" style="background-image:url('/hero-slides/slide-1.jpg')"></div>
      <div class="hero-slide" style="background-image:url('/hero-slides/slide-2.jpg')"></div>
      <div class="hero-slide" style="background-image:url('/hero-slides/slide-3.jpg')"></div>
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Our Gallery</h1>
      <div class="hero-divider"><span></span><span class="scissors">✂</span><span></span></div>
    </div>
  </section>
  <section class="gallery-page-section">
    <div class="container">
      <h2 class="section-title">Our Work</h2>
      <p class="section-intro">Browse a selection of cuts from Eli's Barbershop. Every client gets a personalized cut tailored to their style.</p>
      <div class="gallery-grid" id="galleryGrid">
        {[
          '/gallery/4fb622dc-278d-41ea-a8a3-8249085b6ed2.jpg',
          '/gallery/2018-01-11.jpg',
          '/gallery/2022-05-16.jpg',
          '/gallery/20240214_175751.jpg',
          '/gallery/b0a3f5a8-97d9-4f44-8f10-f64260a350f4.jpg',
          '/gallery/b9391231-9c2f-4c8c-9c37-1879eb64fd91.jpg',
          '/gallery/D3C6117F-D076-4C7D-98C2-9A6E306F8D31.jpeg',
          '/gallery/IMG-20180723-WA0038.jpeg',
          '/gallery/elibarbershop-toronto-canada.jpg',
          '/gallery/elibarbershop-toronto-canada-2.jpg',
          '/gallery/elisbarbershop-1.jpg',
          '/gallery/unnamed.jpg',
          '/gallery/unnamed-2.jpg',
          '/gallery/unnamed-3.jpg',
        ].map((src, i) => (
          <button type="button" class="gallery-item" data-full={src} data-index={i} aria-label={`Open photo ${i + 1} of Eli's Barbershop`}>
            <img src={src} alt={`Eli's Barbershop Cut ${i + 1}`} loading="lazy">
            <span class="gallery-item-overlay" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="10" cy="10" r="6"></circle>
                <line x1="21" y1="21" x2="14.65" y2="14.65"></line>
                <line x1="10" y1="7" x2="10" y2="13"></line>
                <line x1="7" y1="10" x2="13" y2="10"></line>
              </svg>
            </span>
          </button>
        ))}
      </div>
      <div class="gallery-cta">
        <p>Ready for your next look? Book your appointment today.</p>
        <a href="tel:+14162242877" class="btn btn-primary">Call Us: (+1) 416 224 2877</a>
      </div>
    </div>
  </section>
  <section class="services-section">
    <div class="container">
      <div class="services-header">
        <div class="services-header-left">
          <h2 class="section-title">Services</h2>
          <a href="tel:+14162242877" class="btn btn-primary services-phone-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328z"/></svg>
            +1 (416) 224-2877
          </a>
        </div>
        <div class="services-header-right">
          <p>Proudly serving the Toronto area since 2017.</p>
          <p>Whether you need a classic men's cut, a tidy-up for the kids, or a beard trim, we've got you covered. Eli Chanimov has brought years of expertise to the chair, offering simple, stylish cuts that suit every lifestyle. Book an appointment today or just stop by&mdash;good haircuts, done right.</p>
        </div>
      </div>
      <div class="services-grid">
        <div class="service-card service-card-navy">
          <img src="/services/gents-haircut.jpg" alt="" aria-hidden="true">
          <h3>Gents Haircut</h3>
        </div>
        <div class="service-card service-card-tan">
          <img src="/services/beard-trim.jpg" alt="" aria-hidden="true">
          <h3>Beard Trim</h3>
        </div>
        <div class="service-card service-card-outline">
          <img src="/services/salon-services.png" alt="" aria-hidden="true">
          <h3>Salon Services</h3>
        </div>
      </div>
    </div>
  </section>
  <div class="lightbox" id="lightbox">
    <button type="button" class="lightbox-close" id="lightboxClose" aria-label="Close">&times;</button>
    <button type="button" class="lightbox-nav prev" id="lightboxPrev" aria-label="Previous photo">&#10094;</button>
    <img class="lightbox-img" id="lightboxImg" src="" alt="">
    <button type="button" class="lightbox-nav next" id="lightboxNext" aria-label="Next photo">&#10095;</button>
  </div>
</Layout>
